{
  "name": "smart-label-generator",
  "version": "1.0.0",
  "description": "智能标签生成器 - 支持Excel导入和BMP导出",
  "main": "electron/main.js",
  "author": "fy156",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac --x64 --arm64",
    "build:win": "electron-builder --win --x64",
    "build": "npm run build:mac && npm run build:win"
  },
  "build": {
    "appId": "com.yourcompany.smart-label-generator",
    "productName": "SmartLabelGenerator",
    "copyright": "Copyright © 2026 fy156",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "extraMetadata": {
      "name": "smart-label-generator"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "assets/icon.icns",
      "artifactName": "SmartLabelGenerator-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "SmartLabelGenerator-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "fy156",
      "repo": "Smart-Label-Generator"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "xlsx": "^0.18.5",
    "html2canvas": "^1.4.1"
  }
}
